PORT=3002

# Auth — JWT secret for signing user tokens issued by /auth/login and /auth/register.
# Use a long random string in production: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret

# Legacy static token — still accepted by the scraper and internal API calls.
# Leave empty to disable static-token auth.
ADMIN_TOKEN=your-secret-token-here

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=whatsapp_ai

NODE_ENV=development

# IMPORTANT: never commit a real key. Get yours from https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_MS=1000

CRON_SCHEDULE=*/15 * * * *
CRON_ENABLED=true
CRON_MAX_RETRIES=2
CRON_RETRY_DELAY_MS=5000

WA_SESSION_DIR=./wa-session
WA_HEADLESS=false
WA_MESSAGE_LIMIT=50
WA_NAV_TIMEOUT_MS=10000
WA_IDLE_TIMEOUT_MS=10000
WA_GROUPS=AG - Aripra Team(Internal),Autogrid.co.uk,Stock Information issues tracking,Invoice page issues,Call centre developer feedback

SCRAPER_SCHEDULE=*/5 * * * *
SCRAPER_ENABLED=true
API_BASE_URL=http://localhost:3002

# Jira integration — credentials are proxied through the backend; never exposed to the browser
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=you@example.com
JIRA_API_TOKEN=your-jira-api-token-here

# Set to 0 when scraper captures full-res images (default 3 = blur before LLM)
LLM_IMAGE_BLUR_SIGMA=0

# ── Daily Status Feature ───────────────────────────────────────────────────────
# Set DAILY_STATUS_ENABLED=true to activate the daily status collection crons.

# Master switch — must be "true" to activate the two daily-status cron jobs
DAILY_STATUS_ENABLED=false

# Exact WhatsApp group display name (case-sensitive, matches what WA Web shows)
DAILY_STATUS_GROUP=whatsapp ai

# Timezone used for cron scheduling AND for computing session_date.
# Use a tz database name: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Examples: Asia/Kolkata  Europe/London  America/New_York  UTC
DAILY_STATUS_TIMEZONE=Asia/Kolkata

# When to send the reminder (cron syntax, evaluated in DAILY_STATUS_TIMEZONE)
# Default: 11:45 PM every day
DAILY_STATUS_REMINDER_CRON=45 23 * * *

# When to collect replies and send the consolidated summary
# Default: 11:55 PM every day (10 minutes after the reminder)
DAILY_STATUS_COLLECTION_CRON=20 0 * * *

# How many minutes after the reminder to accept user replies.
# Set to 35 when the collection fires at 12:20 AM and reminder is at 11:45 PM.
DAILY_STATUS_WINDOW_MINUTES=35

# Sender name that appears in the messages table for our own WA account.
# Messages from this sender are excluded from the summary.
# In WhatsApp Web, outgoing messages show as "You".
DAILY_STATUS_BOT_SENDER=You

# Text of the reminder message sent to the group.
# Use \n for newlines. Emoji are supported.
DAILY_STATUS_REMINDER_TEXT=🔔 Daily Status Time!\nPlease share your updates for today. You have 10 minutes.
