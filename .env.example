PORT=3002

# Auth — JWT secret for signing user tokens issued by /auth/login and /auth/register.
# Use a long random string in production: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-strong-random-secret

# Legacy static token — still accepted by the scraper and internal API calls.
# Leave empty to disable static-token auth.
ADMIN_TOKEN=your-secret-token-here

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=whatsapp_ai

NODE_ENV=development

# IMPORTANT: never commit a real key. Get yours from https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_MS=1000

CRON_SCHEDULE=*/15 * * * *
CRON_ENABLED=true
CRON_MAX_RETRIES=2
CRON_RETRY_DELAY_MS=5000

WA_SESSION_DIR=./wa-session
WA_HEADLESS=false
WA_MESSAGE_LIMIT=50
WA_NAV_TIMEOUT_MS=10000
WA_IDLE_TIMEOUT_MS=10000
WA_GROUPS=AG - Aripra Team(Internal),Autogrid.co.uk,Stock Information issues tracking,Invoice page issues,Call centre developer feedback

SCRAPER_SCHEDULE=*/5 * * * *
SCRAPER_ENABLED=true
API_BASE_URL=http://localhost:3002

# Jira integration — credentials are proxied through the backend; never exposed to the browser
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_USERNAME=you@example.com
JIRA_API_TOKEN=your-jira-api-token-here
