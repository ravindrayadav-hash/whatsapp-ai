PORT=3001

# Auth — set a strong random string here to enable Bearer-token protection on
# all /api/* routes. Leave empty to disable auth (local dev only).
ADMIN_TOKEN=your-secret-token-here

DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=root
DB_DATABASE=whatsapp_ai

NODE_ENV=development

# IMPORTANT: never commit a real key. Get yours from https://aistudio.google.com/
GEMINI_API_KEY=AIzaSy_REPLACE_WITH_YOUR_KEY
GEMINI_MODEL=gemini-1.5-flash
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_DELAY_MS=1000

CRON_SCHEDULE=*/15 * * * *
CRON_ENABLED=true
CRON_MAX_RETRIES=2
CRON_RETRY_DELAY_MS=5000

WA_SESSION_DIR=./wa-session
WA_HEADLESS=false
WA_MESSAGE_LIMIT=50
WA_NAV_TIMEOUT_MS=60000
WA_IDLE_TIMEOUT_MS=30000
WA_GROUPS=AG - Aripra Team(Internal),Autogrid.co.uk,Stock Information issues tracking,Invoice page issues,Call centre developer feedback

SCRAPER_SCHEDULE=*/5 * * * *
SCRAPER_ENABLED=true
API_BASE_URL=http://localhost:3001
